# Backend env (copy from ../.env.example to .env and fill in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
DATA_DIR=../data

# Optional — only if OS keychain is unavailable on your platform
# ENCRYPTION_PASSPHRASE=

HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO

DAILY_QUOTA=200
MIN_REQUEST_INTERVAL=1.0
MAX_ATTEMPTS=5
